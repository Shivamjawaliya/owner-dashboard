{
  "expo": {
    "name": "HomiePG Owner",
    "slug": "owner-dashboard",
    "version": "1.0.0",
    "scheme": "pgowner",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pgowner.dashboard"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.pgowner.dashboard",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBqU_NElSBtltipC-FDTDt9-XU-3qx-KXE"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow HomiePG Owner to access your location to set building address."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b9e290c4-04f4-4535-8e2f-f96693b083c3"
      }
    }
  }
}
